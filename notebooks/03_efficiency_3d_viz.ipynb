    "# Fuente: repositorio público del proyecto (se añade en la fase de configuración)\n",
    "import urllib.request\n",
    "import os\n",
    "\n",
    "STL_PATH = '../outputs/pump_model.stl'\n",
    "\n",
    "# Alternativamente: crear una representación esquemática con Plotly 3D\n",
    "# si el modelo STL no está disponible.\n",
    "\n",
    "if not os.path.exists(STL_PATH) or not TRIMESH_AVAILABLE:\n",
    "    print('Modelo STL no disponible — generando representación esquemática...')\n",
    "\n",
    "    # Crear esquema 3D de la bomba con formas primitivas en Plotly\n",
    "    def cilindro_plotly(r, h, x0=0, y0=0, z0=0, color='lightblue', N=40, opacity=0.6):\n",
    "        \"\"\"Genera las trazas de superficie de un cilindro en Plotly 3D.\"\"\"\n",
    "        theta = np.linspace(0, 2*np.pi, N)\n",
    "        z     = np.array([z0, z0+h])\n",
    "        T, Z  = np.meshgrid(theta, z)\n",
    "        X = x0 + r * np.cos(T)\n",
    "        Y = y0 + r * np.sin(T)\n",
    "        return go.Surface(x=X, y=Y, z=Z, colorscale=[[0, color],[1, color]],\n",
    "                          opacity=opacity, showscale=False, hoverinfo='skip')\n",
    "\n",
    "    def torus_plotly(R, r, x0=0, y0=0, z0=0, color='steelblue', N=40, opacity=0.7):\n",
    "        \"\"\"Genera un toro (carcasa voluta de la bomba).\"\"\"\n",
    "        u = np.linspace(0, 2*np.pi, N)\n",
    "        v = np.linspace(0, 2*np.pi, N)\n",
    "        U, V = np.meshgrid(u, v)\n",
    "        X = x0 + (R + r*np.cos(V)) * np.cos(U)\n",
    "        Y = y0 + (R + r*np.cos(V)) * np.sin(U)\n",
    "        Z = z0 + r * np.sin(V)\n",
    "        return go.Surface(x=X, y=Y, z=Z, colorscale=[[0, color],[1, color]],\n",
    "                          opacity=opacity, showscale=False, hoverinfo='skip')\n",
    "\n",
    "    fig_pump = go.Figure()\n",
    "\n",
    "    # Voluta (carcasa) — toro\n",
    "    fig_pump.add_trace(torus_plotly(R=1.2, r=0.4, z0=0.5, color='#2196F3', opacity=0.55))\n",
    "\n",
    "    # Motor eléctrico — cilindro\n",
    "    fig_pump.add_trace(cilindro_plotly(r=0.5, h=2.0, x0=0, y0=0, z0=-2.2, color='#607D8B', opacity=0.70))\n",
    "\n",
    "    # Eje\n",
    "    fig_pump.add_trace(cilindro_plotly(r=0.08, h=3.5, x0=0, y0=0, z0=-2.2, color='#FFC107', opacity=0.9))\n",
    "\n",
    "    # Tubería de succión\n",
    "    fig_pump.add_trace(cilindro_plotly(r=0.22, h=1.5, x0=0, y0=-1.2, z0=0.2, color='#78909C', opacity=0.75))\n",
    "\n",
    "    # Tubería de descarga (vertical)\n",
    "    fig_pump.add_trace(cilindro_plotly(r=0.18, h=1.8, x0=1.2, y0=0, z0=0.4, color='#78909C', opacity=0.75))\n",
    "\n",
    "    # Texto de anotación con condiciones actuales del BEP\n",
    "    fig_pump.add_trace(go.Scatter3d(\n",
    "        x=[0], y=[0], z=[2.0],\n",
    "        mode='text',\n",
    "        text=[f'PUNTO DE EFICIENCIA<br>Q = {bep_C[\"Fluj_Desc\"]:.0f} GPM<br>P = {bep_C[\"Potencia\"]:.0f} kW<br>RPM = {bep_C[\"RPM\"]:.0f}'],\n",
    "        textfont=dict(size=9, color='gold'),\n",
    "        hoverinfo='skip'\n",
    "    ))\n",
    "\n",
    "    fig_pump.update_layout(\n",
    "        title=dict(text='Esquema 3D — Bomba Centrífuga con Motor Eléctrico<br><sup>Punto de máxima eficiencia identificado por análisis de clustering</sup>',\n",
    "                   font=dict(size=13)),\n",
    "        scene=dict(\n",
    "            xaxis=dict(backgroundcolor='#060c18', gridcolor='#1e3a5f', color='#7eb8e8',\n",
    "                       showbackground=True, title=''),\n",
    "            yaxis=dict(backgroundcolor='#060c18', gridcolor='#1e3a5f', color='#7eb8e8',\n",
    "                       showbackground=True, title=''),\n",
    "            zaxis=dict(backgroundcolor='#060c18', gridcolor='#1e3a5f', color='#7eb8e8',\n",
