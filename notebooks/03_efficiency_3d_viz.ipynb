   "source": [
    "---\n",
    "## Sección 1 — Pesos Ponderados y Assessment Function\n",
    "\n",
    "El archivo Excel entrega los **pesos** de cada variable pero las columnas **H, HH y V0** están vacías.\n",
    "Las completamos basándonos en:\n",
    "1. Documentación del fabricante (si disponible)\n",
    "2. Rangos observados en el dataset + percentiles de alarma típicos en industria\n",
    "3. Estándares API y IEEE para motores de media tensión\n",
    "\n",
    "**Assessment Function univariable (marco EPI):**\n",
    "```\n",
    "I_i = 1                          si x_i ≤ V0  (óptimo)\n",
    "I_i = 1 - (x_i - V0) / (H - V0) si V0 < x_i ≤ H  (zona de alerta)\n",
    "I_i = 0                          si x_i > HH  (crítico)\n",
    "```\n",
    "El índice global: **EPI = Σ (peso_i × I_i)**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar pesos ponderados del Excel\n",
    "df_weights = pd.read_excel('../Pesos Ponderados - Proyecto6 (1).xlsx', sheet_name='PESOS')\n",
    "df_weights = df_weights.dropna(subset=['VARIABLE'])\n",
    "print('Pesos cargados:')\n",
    "print(df_weights[['ID', 'VARIABLE', 'Pesos', 'División']].to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# -------------------------------------------------------------------\n",
    "# COMPLETAR PARÁMETROS H, HH, V0 — Assessment Function\n",
    "#\n",
    "# Fuentes de referencia:\n",
    "# - V0: percentil 10 de la distribución (condición normal-óptima)\n",
    "# - H:  percentil 90 ó umbral de alerta de fabricante\n",
    "# - HH: límite físico máximo ó umbral de paro de emergencia\n",
    "#\n",
    "# Criterio para temperaturas: IEC 60034 (motores) y API 610 (bombas)\n",
    "# Criterio para presiones: operación histórica + 10% margen\n",
    "# -------------------------------------------------------------------\n",
    "\n",
    "# Mapeo variable_dataset → columna en df\n",
    "assessment_params = {\n",
    "    # Variable              : {'col': nombre_en_df,     'V0': valor, 'H': alerta, 'HH': crítico, 'peso': peso}\n",
    "    'Pres_Succ'             : {'col': 'Pres_Succ',             'V0': None, 'H': None, 'HH': None, 'peso': 3.8},\n",
    "    'Pres_Desc'             : {'col': 'Pres_Desc',             'V0': None, 'H': None, 'HH': None, 'peso': 3.8},\n",
    "    'Fluj_Desc'             : {'col': 'Fluj_Desc',             'V0': None, 'H': None, 'HH': None, 'peso': 4.8},\n",
    "    'Temp_BBA Acople'       : {'col': 'Temp_BBA Acople',       'V0': None, 'H': 135,  'HH': 155,  'peso': 3.0},\n",
    "    'Temp_BBA Oil-in'       : {'col': 'Temp_BBA Oil-in',       'V0': None, 'H': 145,  'HH': 165,  'peso': 2.4},\n",
    "    'Temp_BBA Oil-out'      : {'col': 'Temp_BBA Oil-out',      'V0': None, 'H': 140,  'HH': 160,  'peso': 2.4},\n",
    "    'Temp_BBA Carcasa'      : {'col': 'Temp_BBA Carcasa',      'V0': None, 'H': 145,  'HH': 165,  'peso': 2.8},\n",
    "    'Temp_MTR Acople'       : {'col': 'Temp_MTR Acople',       'V0': None, 'H': 140,  'HH': 160,  'peso': 3.0},\n",
    "    'Temp_MTR Libre'        : {'col': 'Temp_MTR Libre',        'V0': None, 'H': 145,  'HH': 165,  'peso': 2.8},\n",
    "    'Temp_Devanado U'       : {'col': 'Temp_Devanado U',       'V0': None, 'H': 160,  'HH': 180,  'peso': 2.4},\n",
    "    'Temp_Devanado V'       : {'col': 'Temp_Devanado V',       'V0': None, 'H': 160,  'HH': 180,  'peso': 2.4},\n",
    "    'Temp_Devanado W'       : {'col': 'Temp_Devanado W',       'V0': None, 'H': 160,  'HH': 180,  'peso': 2.4},\n",
    "    'Corriente L1'          : {'col': 'Corriente L1',          'V0': None, 'H': None, 'HH': None, 'peso': 3.8},\n",
    "    'Corriente L2'          : {'col': 'Corriente L2',          'V0': None, 'H': None, 'HH': None, 'peso': 3.8},\n",
    "    'Corriente L3'          : {'col': 'Corriente L3',          'V0': None, 'H': None, 'HH': None, 'peso': 3.8},\n",
    "    'Voltaje L1-L2'         : {'col': 'Voltaje L1-L2',         'V0': 4.16, 'H': 4.30, 'HH': 4.40, 'peso': 3.2},\n",
    "    'Voltaje L2-L3'         : {'col': 'Voltaje L2-L3',         'V0': 4.16, 'H': 4.30, 'HH': 4.40, 'peso': 3.2},\n",
    "    'Voltaje L1-L3'         : {'col': 'Voltaje L1-L3',         'V0': 4.16, 'H': 4.30, 'HH': 4.40, 'peso': 3.2},\n",
    "    'Potencia'              : {'col': 'Potencia',              'V0': None, 'H': None, 'HH': None, 'peso': 4.8},\n",
    "    'RPM'                   : {'col': 'RPM',                   'V0': None, 'H': None, 'HH': None, 'peso': 4.8},\n",
    "    'Pos_axial1'            : {'col': 'Pos_axial1',            'V0': None, 'H': None, 'HH': None, 'peso': 3.2},\n",
    "    'Pos_axial2'            : {'col': 'Pos_axial2',            'V0': None, 'H': None, 'HH': None, 'peso': 3.2},\n",
    "}\n",
    "\n",
    "# Auto-completar V0 con percentil 20, H con p85, HH con p95 donde no estén definidos\n",
    "for var, params in assessment_params.items():\n",
    "    col = params['col']\n",
    "    if col not in df_clean.columns:\n",
    "        continue\n",
    "    data = df_clean[col].dropna()\n",
    "    if params['V0'] is None:\n",
    "        params['V0'] = round(data.quantile(0.20), 2)\n",
    "    if params['H'] is None:\n",
    "        params['H']  = round(data.quantile(0.85), 2)\n",
    "    if params['HH'] is None:\n",
    "        params['HH'] = round(data.quantile(0.95), 2)\n",
    "\n",
    "print('Parámetros de Assessment Function completados:')\n",
    "df_params = pd.DataFrame(assessment_params).T.reset_index().rename(columns={'index': 'Variable'})\n",
    "print(df_params[['Variable', 'V0', 'H', 'HH', 'peso']].to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calcular Assessment Function para cada registro\n",
    "def assessment_function(x, V0, H, HH):\n",
    "    \"\"\"Marco EPI — Assessment Function univariable.\"\"\"\n",
    "    if pd.isna(x) or pd.isna(V0) or pd.isna(H) or pd.isna(HH):\n",
    "        return np.nan\n",
    "    if x <= V0:\n",
    "        return 1.0\n",
    "    elif x <= H:\n",
    "        return 1.0 - (x - V0) / (H - V0) * 0.5  # degradación parcial\n",
    "    elif x <= HH:\n",
    "        return 0.5 - (x - H) / (HH - H) * 0.5   # zona de alarma\n",
    "    else:\n",
    "        return 0.0  # crítico\n",
    "\n",
    "# Calcular EPI para el dataset limpio\n",
    "total_peso = sum(p['peso'] for p in assessment_params.values())\n",
    "\n",
    "epi_values = np.zeros(len(df_clean))\n",
    "for var, params in assessment_params.items():\n",
    "    col = params['col']\n",
    "    if col not in df_clean.columns:\n",
    "        continue\n",
    "    peso_norm = params['peso'] / total_peso\n",
    "    V0, H, HH = params['V0'], params['H'], params['HH']\n",
    "    indices_i = df_clean[col].apply(lambda x: assessment_function(x, V0, H, HH)).fillna(0.5)\n",
    "    epi_values += peso_norm * indices_i.values\n",
    "\n",
    "df_clean['EPI'] = epi_values\n",
    "print(f'EPI calculado:')\n",
    "print(f'  Media  : {df_clean[\"EPI\"].mean():.4f}')\n",
    "print(f'  Mediana: {df_clean[\"EPI\"].median():.4f}')\n",
    "print(f'  Min    : {df_clean[\"EPI\"].min():.4f}')\n",
    "print(f'  Max    : {df_clean[\"EPI\"].max():.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Sección 2 — Determinación del Punto de Eficiencia\n",
    "\n",
    "### Contexto físico\n",
    "\n",
    "Una bomba centrífuga tiene un **BEP (Best Efficiency Point)** — la condición de flujo y velocidad donde la relación entre potencia consumida y trabajo hidráulico realizado es máxima. Alejarse del BEP aumenta el consumo energético, el desgaste mecánico y el riesgo de cavitación.\n",
    "\n",
    "Dado que no conocemos la densidad del crudo (varía según tipo), usamos **tres proxies complementarios**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ===================================================================\n",
    "# MÉTODO A — Mínimo de Potencia Específica (kW / GPM)\n",
    "# ===================================================================\n",
    "# Potencia_especifica = Potencia [kW] / Flujo [GPM]\n",
    "# Menor valor → motor mueve más fluido por cada kW consumido → más eficiente\n",
    "# Limitación: asume densidad constante (válido como comparación relativa)\n",
    "# ===================================================================\n",
    "\n",
    "# Solo puntos con flujo significativo\n",
    "df_eff = df_clean[(df_clean['Fluj_Desc'] > 500) & (df_clean['Potencia'] > 100)].copy()\n",
    "df_eff['Pot_especifica'] = df_eff['Potencia'] / df_eff['Fluj_Desc']\n",
    "\n",
    "# Añadir cluster\n",
    "df_eff = df_eff.reset_index(drop=True)\n",
    "\n",
    "# Punto de mínima potencia específica\n",
    "idx_min_A = df_eff['Pot_especifica'].idxmin()\n",
    "bep_A = df_eff.loc[idx_min_A, ['RPM', 'Fluj_Desc', 'Potencia', 'Pres_Desc', 'TDH_PSI', 'Pot_especifica']]\n",
    "\n",
    "print('=== MÉTODO A: Mínimo Potencia Específica ===')\n",
    "print(f'  RPM             : {bep_A[\"RPM\"]:.0f}')\n",
    "print(f'  Flujo Desc      : {bep_A[\"Fluj_Desc\"]:.0f} GPM')\n",
    "print(f'  Potencia        : {bep_A[\"Potencia\"]:.0f} kW')\n",
    "print(f'  Presión Desc    : {bep_A[\"Pres_Desc\"]:.0f} PSI')\n",
    "print(f'  TDH             : {bep_A[\"TDH_PSI\"]:.0f} PSI')\n",
    "print(f'  Pot. Específica : {bep_A[\"Pot_especifica\"]:.4f} kW/GPM')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ===================================================================\n",
    "# MÉTODO B — Máximo del Índice EPI (Desempeño Ponderado)\n",
    "# ===================================================================\n",
    "# Busca el cluster donde el EPI promedio es más alto\n",
    "# (mejor estado general del equipo según los pesos del Assessment)\n",
    "# ===================================================================\n",
    "\n",
    "# Asignar clusters al df_clean (por índice, asumiendo mismo orden)\n",
    "# Solo si el índice coincide con df (features)\n",
    "if len(df_clean) == len(df):\n",
    "    df_clean['cluster_km'] = df['cluster_km'].values\n",
    "else:\n",
    "    # Reasignar con el modelo si los tamaños difieren\n",
    "    scaler_loaded = model_data['scaler']\n",
    "    km_loaded     = model_data['kmeans']\n",
    "    feat_available = [f for f in FEATURES if f in df_clean.columns]\n",
    "    X_clean = df_clean[feat_available].dropna()\n",
    "    df_clean.loc[X_clean.index, 'cluster_km'] = km_loaded.predict(scaler_loaded.transform(X_clean))\n",
    "\n",
    "epi_por_cluster = df_clean.groupby('cluster_km')['EPI'].agg(['mean', 'std', 'count'])\n",
    "epi_por_cluster.columns = ['EPI_mean', 'EPI_std', 'n_registros']\n",
    "best_cluster_B  = epi_por_cluster['EPI_mean'].idxmax()\n",
    "\n",
    "print('=== MÉTODO B: Máximo EPI por Cluster ===')\n",
    "print(epi_por_cluster.round(4).to_string())\n",
    "print(f'\\nCluster con mayor EPI: {best_cluster_B} (EPI = {epi_por_cluster.loc[best_cluster_B, \"EPI_mean\"]:.4f})')\n",
    "\n",
    "# Centroide del cluster óptimo\n",
    "centroide_B = df_clean[df_clean['cluster_km'] == best_cluster_B][FEATURES].mean()\n",
    "print(f'\\nCondiciones del modo óptimo (centroide Cluster {best_cluster_B}):')\n",
    "for feat in ['RPM', 'Fluj_Desc', 'Potencia', 'Pres_Desc']:\n",
    "    if feat in centroide_B:\n",
    "        print(f'  {feat:<20}: {centroide_B[feat]:.1f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ===================================================================\n",
    "# MÉTODO C — BEP sobre curva H-Q (ajuste polinomial)\n",
    "# ===================================================================\n",
    "# La curva H-Q (Head vs Flow) es la firma característica de la bomba.\n",
    "# El BEP se ubica donde la eficiencia hidráulica η es máxima:\n",
    "#   η = ρ·g·Q·H / P_shaft\n",
    "# Sin conocer ρ (densidad del crudo), usamos η_proxy = Q·TDH / Potencia\n",
    "# (proporcional a η real si ρ es constante en cada modo)\n",
    "# ===================================================================\n",
    "\n",
    "df_hq = df_clean[(df_clean['Fluj_Desc'] > 500) & (df_clean['Potencia'] > 100)].copy()\n",
    "\n",
    "# η_proxy (sin ρ y conversión de unidades)\n",
    "# [GPM × PSI / kW] — proporcional a la eficiencia hidráulica relativa\n",
    "# Conversión aproximada: 1 GPM·PSI = 0.002228 kW (eficiencia teórica de líquido incompresible)\n",
    "GPM_PSI_TO_KW = 0.002228\n",
    "df_hq['eta_proxy'] = (df_hq['Fluj_Desc'] * df_hq['TDH_PSI'] * GPM_PSI_TO_KW) / df_hq['Potencia']\n",
    "\n",
    "# Ajuste polinomial de curva η vs Q (para estimar BEP suavizado)\n",
    "Q_vals   = df_hq['Fluj_Desc'].values\n",
    "eta_vals = df_hq['eta_proxy'].values\n",
    "\n",
    "# Filtrar outliers del ajuste con IQR\n",
    "eta_q1, eta_q3 = np.percentile(eta_vals, 25), np.percentile(eta_vals, 75)\n",
    "eta_iqr = eta_q3 - eta_q1\n",
    "mask_fit = (eta_vals > eta_q1 - 1.5*eta_iqr) & (eta_vals < eta_q3 + 1.5*eta_iqr)\n",
    "\n",
    "deg = 4  # polinomio de grado 4 para curva de eficiencia\n",
    "coeffs = np.polyfit(Q_vals[mask_fit], eta_vals[mask_fit], deg)\n",
    "poly   = np.poly1d(coeffs)\n",
    "\n",
    "Q_range = np.linspace(Q_vals[mask_fit].min(), Q_vals[mask_fit].max(), 500)\n",
    "eta_curve = poly(Q_range)\n",
    "\n",
    "# BEP = máximo de la curva ajustada\n",
    "idx_bep_C = np.argmax(eta_curve)\n",
    "Q_bep_C   = Q_range[idx_bep_C]\n",
    "eta_bep_C = eta_curve[idx_bep_C]\n",
    "\n",
    "# Encontrar condición real más cercana al BEP\n",
    "dist_to_bep = np.abs(df_hq['Fluj_Desc'] - Q_bep_C)\n",
    "idx_closest_C = dist_to_bep.idxmin()\n",
    "bep_C = df_hq.loc[idx_closest_C, ['RPM', 'Fluj_Desc', 'Potencia', 'Pres_Desc', 'TDH_PSI', 'eta_proxy']]\n",
    "\n",
    "print('=== MÉTODO C: BEP sobre curva η-Q ===')\n",
    "print(f'  Q BEP (ajuste) : {Q_bep_C:.0f} GPM')\n",
    "print(f'  η_proxy BEP    : {eta_bep_C:.4f}')\n",
    "print(f'\\n  Punto real más cercano al BEP:')\n",
    "print(f'  RPM          : {bep_C[\"RPM\"]:.0f}')\n",
    "print(f'  Flujo        : {bep_C[\"Fluj_Desc\"]:.0f} GPM')\n",
    "print(f'  Potencia     : {bep_C[\"Potencia\"]:.0f} kW')\n",
    "print(f'  TDH          : {bep_C[\"TDH_PSI\"]:.0f} PSI')\n",
    "print(f'  η_proxy      : {bep_C[\"eta_proxy\"]:.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualización curva H-Q y curva de eficiencia — Plotly interactivo\n",
    "sample = df_hq.sample(min(10000, len(df_hq)), random_state=42)\n",
    "\n",
    "fig = make_subplots(rows=2, cols=1, subplot_titles=['Curva H-Q (Head vs Flow)', 'Curva de Eficiencia η_proxy vs Flujo'],\n",
    "                    vertical_spacing=0.12)\n",
    "\n",
    "# H-Q scatter\n",
    "fig.add_trace(go.Scatter(\n",
    "    x=sample['Fluj_Desc'], y=sample['TDH_PSI'],\n",
    "    mode='markers', name='Datos H-Q',\n",
    "    marker=dict(size=2, color='#4FC3F7', opacity=0.3)\n",
    "), row=1, col=1)\n",
    "\n",
    "# BEP punto en H-Q\n",
    "fig.add_trace(go.Scatter(\n",
    "    x=[bep_C['Fluj_Desc']], y=[bep_C['TDH_PSI']],\n",
    "    mode='markers+text', name='BEP (Método C)',\n",
    "    marker=dict(size=14, color='#FFD54F', symbol='star'),\n",
    "    text=['BEP'], textposition='top right'\n",
    "), row=1, col=1)\n",
    "\n",
    "# Curva eta\n",
    "fig.add_trace(go.Scatter(\n",
    "    x=sample['Fluj_Desc'], y=sample['eta_proxy'],\n",
    "    mode='markers', name='η_proxy datos',\n",
    "    marker=dict(size=2, color='#81C784', opacity=0.2)\n",
    "), row=2, col=1)\n",
    "\n",
    "fig.add_trace(go.Scatter(\n",
